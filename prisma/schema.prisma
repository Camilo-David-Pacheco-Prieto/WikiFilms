generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum WatchStatus {
  WATCHED
  PLAN_TO_WATCH
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  username       String          @unique
  password       String
  role           Role            @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  favorites      Favorite[]
  watchlistItems WatchlistItem[]
  reviews        Review[]
  reviewComments ReviewComment[]
  reviewReactions ReviewReaction[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  contentId Int
  title     String
  posterUrl String?
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model WatchlistItem {
  id        String      @id @default(cuid())
  userId    String
  contentId Int
  title     String
  posterUrl String?
  type      String
  status    WatchStatus @default(PLAN_TO_WATCH)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

enum ReactionType {
  LIKE
  DISLIKE
}

model Review {
  id        String           @id @default(cuid())
  userId    String
  contentId Int
  rating    Int
  comment   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  ReviewComment[]
  reactions ReviewReaction[]

  @@unique([userId, contentId])
}

model ReviewComment {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  comment   String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReviewReaction {
  id        String       @id @default(cuid())
  reviewId  String
  userId    String
  type      ReactionType
  review    Review       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}